// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id         String   @id @default(uuid())
  username   String
  email      String   @unique
  password   String
  avatar_url String?
  bio        String?
  xp         Int      @default(0)
  level      Int      @default(1)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  respostas_usuario RespostaUsuario[]
  progresso_trilha  ProgressoTrilhaUsuario[]
  bloqueios_trilha  BloqueioTrilhaUsuario[]
  conquistas        ConquistaUsuario[]
  rankings          Ranking[]
  habilidades       HabilidadeUsuario[]

  @@map("usuarios")
}

enum NameAssunto {
  JS
}

model Assunto {
  id          String      @id @default(uuid())
  name        NameAssunto @default(JS)
  description String?
  created_at  DateTime    @default(now())

  trilhas TrilhaAprendizado[]

  @@map("assuntos")
}

model TrilhaAprendizado {
  id               String   @id @default(uuid())
  subject_id       String
  title            String
  description      String?
  difficulty_level Int
  minimum_score    Int
  order_index      Int
  is_locked        Boolean  @default(true)
  created_at       DateTime @default(now())

  assunto   Assunto                  @relation(fields: [subject_id], references: [id])
  modulos   Modulo[]
  progresso ProgressoTrilhaUsuario[]
  bloqueios BloqueioTrilhaUsuario[]

  @@map("trilhas_aprendizado")
}

model Modulo {
  id          String   @id @default(uuid())
  track_id    String
  title       String
  description String?
  order_index Int
  created_at  DateTime @default(now())

  trilha   TrilhaAprendizado @relation(fields: [track_id], references: [id])
  questoes Questao[]

  @@map("modulos")
}

model Questao {
  id            String   @id @default(uuid())
  module_id     String
  title         String
  description   String
  difficulty    Int
  xp_reward     Int
  minimum_score Int
  order_index   Int
  created_at    DateTime @default(now())

  modulo            Modulo            @relation(fields: [module_id], references: [id])
  respostas         Resposta[]
  respostas_usuario RespostaUsuario[]

  @@map("questoes")
}

model Resposta {
  id                String   @id @default(uuid())
  question_id       String
  answer_content    String
  is_correct        Boolean
  clean_code_score  Int
  performance_score Int
  readability_score Int
  created_at        DateTime @default(now())

  questao           Questao           @relation(fields: [question_id], references: [id])
  respostas_usuario RespostaUsuario[]

  @@map("respostas")
}

model RespostaUsuario {
  id                String   @id @default(uuid())
  user_id           String
  question_id       String
  answer_id         String
  final_score       Int
  positive_feedback String?
  negative_feedback String?
  is_completed      Boolean  @default(false)
  answered_at       DateTime @default(now())

  usuario  Usuario  @relation(fields: [user_id], references: [id])
  questao  Questao  @relation(fields: [question_id], references: [id])
  resposta Resposta @relation(fields: [answer_id], references: [id])

  avaliacoes AvaliacaoResposta[]

  @@map("respostas_usuario")
}

model ProgressoTrilhaUsuario {
  id                  String    @id @default(uuid())
  user_id             String
  track_id            String
  current_module_id   String?
  current_question_id String?
  progress_percentage Int
  is_completed        Boolean   @default(false)
  started_at          DateTime  @default(now())
  completed_at        DateTime?

  usuario Usuario           @relation(fields: [user_id], references: [id])
  trilha  TrilhaAprendizado @relation(fields: [track_id], references: [id])

  @@map("progresso_trilha_usuario")
}

model BloqueioTrilhaUsuario {
  id          String    @id @default(uuid())
  user_id     String
  track_id    String
  is_unlocked Boolean   @default(false)
  unlocked_at DateTime?

  usuario Usuario           @relation(fields: [user_id], references: [id])
  trilha  TrilhaAprendizado @relation(fields: [track_id], references: [id])

  @@map("bloqueios_trilha_usuario")
}

model Conquista {
  id          String   @id @default(uuid())
  title       String
  description String?
  icon        String?
  xp_reward   Int
  created_at  DateTime @default(now())

  usuarios ConquistaUsuario[]

  @@map("conquistas")
}

model ConquistaUsuario {
  id             String   @id @default(uuid())
  user_id        String
  achievement_id String
  unlocked_at    DateTime @default(now())

  usuario   Usuario   @relation(fields: [user_id], references: [id])
  conquista Conquista @relation(fields: [achievement_id], references: [id])

  @@map("conquistas_usuario")
}

model Ranking {
  id         String   @id @default(uuid())
  user_id    String
  total_xp   Int
  position   Int
  updated_at DateTime @updatedAt

  usuario Usuario @relation(fields: [user_id], references: [id])

  @@map("rankings")
}

model Habilidade {
  id          String  @id @default(uuid())
  name        String
  description String?

  usuarios HabilidadeUsuario[]

  @@map("habilidades")
}

model HabilidadeUsuario {
  id         String   @id @default(uuid())
  user_id    String
  skill_id   String
  score      Int
  level      Int
  updated_at DateTime @updatedAt

  usuario    Usuario    @relation(fields: [user_id], references: [id])
  habilidade Habilidade @relation(fields: [skill_id], references: [id])

  @@map("habilidades_usuario")
}

model CriterioAvaliacao {
  id          String  @id @default(uuid())
  name        String
  description String?
  weight      Int

  avaliacoes AvaliacaoResposta[]

  @@map("criterios_avaliacao")
}

model AvaliacaoResposta {
  id             String  @id @default(uuid())
  user_answer_id String
  criteria_id    String
  score          Int
  feedback       String?

  resposta_usuario RespostaUsuario   @relation(fields: [user_answer_id], references: [id])
  criterio         CriterioAvaliacao @relation(fields: [criteria_id], references: [id])

  @@map("avaliacoes_resposta")
}
