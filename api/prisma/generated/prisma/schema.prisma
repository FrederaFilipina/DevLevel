generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id String @id @default(uuid())

  nome  String
  email String @unique
  senha String

  role Role @default(USER)

  avatarUrl String?
  bio       String?

  xp    Int @default(0)
  nivel Int @default(1)

  pontuacaoTotal Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trilhasUsuario   TrilhaUsuario[]
  respostasUsuario RespostaUsuario[]

  temasUsuario TemaUsuario[]

  conquistasUsuario  ConquistaUsuario[]
  habilidadesUsuario HabilidadeUsuario[]
  insigniasUsuario   InsigniaUsuario[]

  rankings Ranking[]
  tokens   Token[]

  @@map("usuario")
}

model Tema {
  id String @id @default(uuid())

  nome      String  @unique
  descricao String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trilhas  Trilha[]
  usuarios TemaUsuario[]

  insignias InsigniaUsuario[]

  @@map("tema")
}

model TemaUsuario {
  id String @id @default(uuid())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  temaId String
  tema   Tema   @relation(fields: [temaId], references: [id])

  pontuacaoTotal Int @default(0)

  trilhasConcluidas Int @default(0)

  nivelAtual NivelDificuldade @default(INICIANTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([usuarioId, temaId])
  @@map("tema_usuario")
}

model Trilha {
  id String @id @default(uuid())

  temaId String
  tema   Tema   @relation(fields: [temaId], references: [id])

  titulo    String
  descricao String?

  nivel NivelDificuldade

  ordem Int

  pontuacaoMinima Int

  trilhaAnteriorId String?
  trilhaAnterior   Trilha? @relation("ProgressaoTrilha", fields: [trilhaAnteriorId], references: [id])

  proximasTrilhas Trilha[] @relation("ProgressaoTrilha")

  modulos  Modulo[]
  usuarios TrilhaUsuario[]

  insignias InsigniaUsuario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("trilha")
}

enum NivelDificuldade {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
}

model Modulo {
  id String @id @default(uuid())

  trilhaId String
  trilha   Trilha @relation(fields: [trilhaId], references: [id])

  titulo    String
  descricao String?

  ordem Int

  questoes Questao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("modulo")
}

model Questao {
  id String @id @default(uuid())

  moduloId String
  modulo   Modulo @relation(fields: [moduloId], references: [id])

  titulo    String
  descricao String @db.Text

  dificuldade Int

  xpRecompensa Int

  ordem Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  respostas        RespostaQuestao[]
  respostasUsuario RespostaUsuario[]

  @@map("questao")
}

model RespostaQuestao {
  id String @id @default(uuid())

  questaoId String
  questao   Questao @relation(fields: [questaoId], references: [id])

  titulo String

  codigoResposta String @db.Text

  explicacao String? @db.Text

  pontuacao Int

  cleanCodeScore    Int
  performanceScore  Int
  legibilidadeScore Int

  pontosPositivos String? @db.Text
  pontosNegativos String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  respostasUsuarios RespostaUsuario[]

  @@map("resposta_questao")
}

model RespostaUsuario {
  id String @id @default(uuid())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  questaoId String
  questao   Questao @relation(fields: [questaoId], references: [id])

  respostaQuestaoId String
  respostaQuestao   RespostaQuestao @relation(fields: [respostaQuestaoId], references: [id])

  pontuacaoRecebida Int

  respondidaEm DateTime @default(now())

  @@unique([usuarioId, questaoId])
  @@map("resposta_usuario")
}

model TrilhaUsuario {
  id String @id @default(uuid())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  trilhaId String
  trilha   Trilha @relation(fields: [trilhaId], references: [id])

  status StatusTrilhaUsuario @default(EM_ANDAMENTO)

  pontuacaoAtual Int @default(0)

  pontuacaoNecessaria Int

  percentualConclusao Int @default(0)

  podeDesbloquear Boolean @default(false)

  moduloAtualId  String?
  questaoAtualId String?

  iniciadaEm  DateTime  @default(now())
  concluidaEm DateTime?

  @@unique([usuarioId, trilhaId])
  @@map("trilha_usuario")
}

enum StatusTrilhaUsuario {
  EM_ANDAMENTO
  CONCLUIDA
  AGUARDANDO_REVISAO
  BLOQUEADA
}

model Conquista {
  id String @id @default(uuid())

  titulo    String
  descricao String?

  icone String?

  xpRecompensa Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios ConquistaUsuario[]

  @@map("conquista")
}

model ConquistaUsuario {
  id String @id @default(uuid())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  conquistaId String
  conquista   Conquista @relation(fields: [conquistaId], references: [id])

  desbloqueadaEm DateTime @default(now())

  @@map("conquista_usuario")
}

model Habilidade {
  id String @id @default(uuid())

  nome      String
  descricao String?

  usuarios HabilidadeUsuario[]

  @@map("habilidade")
}

model HabilidadeUsuario {
  id String @id @default(uuid())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  habilidadeId String
  habilidade   Habilidade @relation(fields: [habilidadeId], references: [id])

  pontuacao Int @default(0)

  nivel Int @default(1)

  updatedAt DateTime @updatedAt

  @@map("habilidade_usuario")
}

model Insignia {
  id String @id @default(uuid())

  titulo    String
  descricao String?

  icone String?

  tipo TipoInsignia

  xpRecompensa Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios InsigniaUsuario[]

  @@map("insignia")
}

enum TipoInsignia {
  CONCLUSAO_TRILHA
  APROVACAO_TRILHA
  MESTRE_TEMA
}

model InsigniaUsuario {
  id String @id @default(uuid())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  insigniaId String
  insignia   Insignia @relation(fields: [insigniaId], references: [id])

  temaId String?
  tema   Tema?   @relation(fields: [temaId], references: [id])

  trilhaId String?
  trilha   Trilha? @relation(fields: [trilhaId], references: [id])

  desbloqueadaEm DateTime @default(now())

  @@map("insignia_usuario")
}

model Ranking {
  id String @id @default(uuid())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  xpTotal Int

  posicao Int

  updatedAt DateTime @updatedAt

  @@map("ranking")
}

enum Role {
  USER
  ADMIN
}

enum TypeToken {
  ACCESS
  REFRESH
}

model Token {
  id        Int       @id @default(autoincrement())
  token     String    @db.Text
  type      TypeToken @default(ACCESS)
  revoked   Boolean   @default(false)
  expiresAt DateTime
  usuarioId String

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("token")
}
